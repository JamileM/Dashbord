<script>
const TOKEN = "SEU_TOKEN_AQUI";
const PROJECT_ID = "SEU_ID_AQUI";

async function carregarDados() {
    const response = await fetch(
        `https://gitlab.com/api/v4/projects/${PROJECT_ID}/issues`,
        {
            headers: {
                "PRIVATE-TOKEN": TOKEN
            }
        }
    );

    const data = await response.json();

    let total = data.length;
    let abertas = data.filter(i => i.state === "opened").length;
    let fechadas = data.filter(i => i.state === "closed").length;

    // KPI
    document.querySelectorAll(".card h2")[0].innerText = total;
    document.querySelectorAll(".card h2")[1].innerText = abertas;
    document.querySelectorAll(".card h2")[2].innerText = fechadas;

    // gráfico status
    new Chart(document.getElementById('statusChart'), {
        type: 'bar',
        data: {
            labels: ['Abertas','Fechadas'],
            datasets: [{
                data: [abertas, fechadas],
                backgroundColor: ['#007bff','#28a745']
            }]
        }
    });
}

carregarDados();
</script>